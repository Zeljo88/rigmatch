@RigMatch.Api_HostAddress = http://localhost:5168

### Upload CV file (PDF/DOC/DOCX)
POST {{RigMatch.Api_HostAddress}}/cv/upload
Content-Type: multipart/form-data; boundary=RigMatchBoundary

--RigMatchBoundary
Content-Disposition: form-data; name="file"; filename="sample.pdf"
Content-Type: application/pdf

< ./sample.pdf
--RigMatchBoundary--

### Extract text from PDF CV (Day 2)
POST {{RigMatch.Api_HostAddress}}/cv/extract-text
Content-Type: multipart/form-data; boundary=RigMatchBoundary

--RigMatchBoundary
Content-Disposition: form-data; name="file"; filename="sample.pdf"
Content-Type: application/pdf

< ./sample.pdf
--RigMatchBoundary--

### Parse CV from uploaded PDF (Day 3)
POST {{RigMatch.Api_HostAddress}}/cv/parse
Content-Type: multipart/form-data; boundary=RigMatchBoundary

--RigMatchBoundary
Content-Disposition: form-data; name="file"; filename="sample.pdf"
Content-Type: application/pdf

< ./sample.pdf
--RigMatchBoundary--

### Parse CV from raw text (Day 3)
POST {{RigMatch.Api_HostAddress}}/cv/parse-text
Content-Type: application/json

{
  "cvText": "John Doe\njohn.doe@example.com\nSenior Software Engineer with 8 years of experience in .NET, Azure, SQL, and Angular."
}
