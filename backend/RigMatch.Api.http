@RigMatch.Api_HostAddress = http://localhost:5168
@authToken = REPLACE_WITH_JWT

### Auth: Register employer
POST {{RigMatch.Api_HostAddress}}/auth/register
Content-Type: application/json

{
  "companyName": "RigMatch Demo Company",
  "fullName": "Demo Employer",
  "email": "demo@rigmatch.local",
  "password": "ChangeMe123"
}

### Auth: Login employer
POST {{RigMatch.Api_HostAddress}}/auth/login
Content-Type: application/json

{
  "email": "demo@rigmatch.local",
  "password": "ChangeMe123"
}

### Auth: Current employer
GET {{RigMatch.Api_HostAddress}}/auth/me
Authorization: Bearer {{authToken}}

### Company: Upload single CV (PDF) and parse draft
POST {{RigMatch.Api_HostAddress}}/company/cv/upload
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=RigMatchBoundary

--RigMatchBoundary
Content-Disposition: form-data; name="file"; filename="sample.pdf"
Content-Type: application/pdf

< ./sample.pdf
--RigMatchBoundary--

### Company: Save final edited profile JSON
POST {{RigMatch.Api_HostAddress}}/company/cv/{{cvId}}/save
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "finalProfile": {
    "name": "John Doe",
    "email": "john.doe@example.com",
    "location": "Abu Dhabi",
    "jobTitles": ["Senior Software Engineer"],
    "companies": ["Contoso"],
    "skills": [".NET", "Azure"],
    "certifications": ["AZ-204"],
    "experienceYears": 8,
    "experiences": [
      {
        "companyName": "Contoso",
        "role": "Junior Petroleum Operator",
        "startDate": "2020-01",
        "endDate": "2023-01",
        "description": "Field operations"
      },
      {
        "companyName": "Contoso",
        "role": "Petroleum Operator",
        "startDate": "2023-02",
        "endDate": "Present",
        "description": "Lead operations"
      }
    ]
  }
}

### Company: List saved CVs
GET {{RigMatch.Api_HostAddress}}/company/cvs
Authorization: Bearer {{authToken}}

### Company: Delete CV record
DELETE {{RigMatch.Api_HostAddress}}/company/cv/{{cvId}}
Authorization: Bearer {{authToken}}
